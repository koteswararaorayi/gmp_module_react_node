# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=infinextg_ricon
DB_PORT=3306

# Server
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_super_secret_key_change_in_production_min_32_chars
JWT_EXPIRY=24h
JWT_REFRESH_SECRET=your_refresh_secret_key_change_in_production
